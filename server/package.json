{
  "name": "@pluvus/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test tsx --test \"src/**/*.test.ts\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx prisma/seed.demo.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "harness": "cross-env NODE_ENV=production tsx --no-warnings src/engine/harness.ts",
    "harness:phase4": "cross-env NODE_ENV=production tsx --no-warnings src/workers/harness.ts",
    "harness:phase5": "cross-env NODE_ENV=production tsx --no-warnings src/scheduler/harness.ts",
    "harness:phase6": "cross-env NODE_ENV=production tsx --no-warnings src/webhooks/harness.ts",
    "harness:phase7": "cross-env NODE_ENV=production tsx --no-warnings src/classification/harness.ts",
    "harness:phase8": "cross-env NODE_ENV=production tsx --no-warnings src/negotiation/harness.ts",
    "harness:phase9": "cross-env NODE_ENV=production tsx --no-warnings src/observability/harness.ts",
    "harness:content-brief": "cross-env NODE_ENV=production tsx --no-warnings src/engine/contentBrief.harness.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.0.0",
    "@types/pg": "^8.20.0",
    "bullmq": "^5.79.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.11.1",
    "multer": "^2.2.0",
    "nylas": "^8.3.0",
    "pg": "^8.22.0",
    "redis": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "cross-env": "^10.1.0",
    "prisma": "^7.0.0",
    "tsx": "^4.15.5",
    "typescript": "^5.5.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
