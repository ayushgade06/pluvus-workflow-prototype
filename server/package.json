{
  "name": "@pluvus/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false --include ../.env src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "start:api": "cross-env PROCESS_ROLE=api node dist/index.js",
    "start:worker": "cross-env PROCESS_ROLE=worker node dist/index.js",
    "start:scheduler": "cross-env PROCESS_ROLE=scheduler node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test tsx --test \"src/**/*.test.ts\"",
    "db:pull": "drizzle-kit pull",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx prisma/seed.demo.ts",
    "db:clean:harness": "tsx scripts/cleanHarnessData.ts",
    "db:clean:harness:apply": "tsx scripts/cleanHarnessData.ts --apply --drain-queues",
    "harness": "cross-env NODE_ENV=production tsx --no-warnings src/engine/harness.ts",
    "harness:phase4": "cross-env NODE_ENV=production tsx --no-warnings src/workers/harness.ts",
    "harness:phase5": "cross-env NODE_ENV=production tsx --no-warnings src/scheduler/harness.ts",
    "harness:phase6": "cross-env NODE_ENV=production tsx --no-warnings src/webhooks/harness.ts",
    "harness:phase7": "cross-env NODE_ENV=production tsx --no-warnings src/classification/harness.ts",
    "harness:phase8": "cross-env NODE_ENV=production tsx --no-warnings src/negotiation/harness.ts",
    "harness:phase9": "cross-env NODE_ENV=production tsx --no-warnings src/observability/harness.ts",
    "harness:content-brief": "cross-env NODE_ENV=production tsx --no-warnings src/engine/contentBrief.harness.ts",
    "harness:payouts": "cross-env NODE_ENV=production tsx --no-warnings src/engine/payouts.harness.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "bullmq": "^5.79.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "multer": "^2.2.0",
    "nylas": "^8.3.0",
    "redis": "^6.0.0",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.15.5",
    "typescript": "^5.5.2"
  }
}
