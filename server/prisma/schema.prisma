// =============================================================================
// Pluvus Workflow Prototype — Prisma Schema
// Architecture ref: .claude/docs/system-architecture.md §6
//
// Design principles:
//   - Definition models (Workflow, WorkflowVersion) are separated from
//     execution models (ExecutionInstance, Message, Event).
//   - WorkflowVersion is immutable once published. Node configs are stored
//     as a JSON snapshot so instances stay pinned to the version they enrolled
//     under, regardless of later edits to the Workflow.
//   - ExecutionInstance is the unit of execution, scheduling, and audit.
//   - Event is append-only. Never update or delete rows.
//   - Message stores every inbound and outbound email tied to an instance,
//     with fields for Nylas thread/message id correlation (Phase 6).
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// The lifecycle state of a single creator running through a workflow.
/// Source of truth: source-of-truth.md §6
enum InstanceState {
  ENROLLED
  OUTREACH_SENT
  AWAITING_REPLY
  FOLLOWED_UP
  REPLY_RECEIVED
  NEGOTIATING
  // A business escalation is parked here waiting on the brand's decision, reached
  // instead of MANUAL_REVIEW whenever a human is making a genuine business call
  // (unclassifiable creator reply, max negotiation rounds, rate above ceiling).
  // NOT terminal: the run resumes automatically on the brand's reply (or a
  // magic-link click). Mirrors the REWARD_PENDING / PAYMENT_PENDING waiting
  // states, but the round-trip is with the brand rather than the creator. Pure
  // safety/infra failures still go straight to MANUAL_REVIEW.
  AWAITING_BRAND_DECISION
  // Negotiation succeeded on an agreed rate. No longer terminal: the Reward
  // Setup node auto-runs from here to finalize the commercial agreement.
  ACCEPTED
  // Reward Setup: confirmation email sent; waiting on the creator to reply
  // "I Agree". Stays here until an agreement reply is detected.
  REWARD_PENDING
  // Reward Setup: creator confirmed the agreement. No longer terminal: the
  // Payment Info node auto-runs from here to collect the creator's payout info.
  REWARD_CONFIRMED
  // Payment Info: payout form emailed; waiting on the creator to submit their
  // payout details via the hosted form. Stays here until a submission arrives.
  PAYMENT_PENDING
  // Payment Info: creator submitted their payout information. No longer terminal:
  // the Content Brief node auto-runs from here to send the campaign brief.
  PAYMENT_RECEIVED
  // Content Brief: the campaign-brief email (PDF attachment + referral link) was
  // sent to the creator. The node has no waiting state — it sends and completes
  // immediately — so this is the single new success terminal state.
  CONTENT_BRIEF_SENT
  // Terminal states
  REJECTED
  OPTED_OUT
  NO_RESPONSE
  // Requires human review (low-confidence classification, Phase 7)
  MANUAL_REVIEW
}

/// The node types that make up the in-scope linear workflow.
/// Stored here so node snapshots inside WorkflowVersion.nodeGraph can be
/// validated at the application layer without magic strings.
enum NodeType {
  IMPORT_CREATOR_LIST
  INITIAL_OUTREACH
  FOLLOW_UP
  REPLY_DETECTION
  NEGOTIATION
  // Finalizes the commercial agreement after a successful negotiation: records
  // the agreed fee/commission/deliverables, emails the creator for confirmation,
  // and waits for their agreement reply.
  REWARD_SETUP
  // Collects the creator's payout information after they confirm the agreement:
  // emails a link to a hosted payout form and waits for the submission before
  // handing control back to the workflow engine.
  PAYMENT_INFO
  // Sends the campaign brief (PDF attachment + referral link + optional notes)
  // once the payout information is collected, then completes immediately. New
  // terminal node in the linear graph.
  CONTENT_BRIEF
  END
}

/// Direction of a message: sent by us (OUTBOUND) or received (INBOUND).
enum MessageDirection {
  OUTBOUND
  INBOUND
}

/// The classified intent of an inbound reply. Populated by the LangGraph
/// classify operation (Phase 7). NULL until classification runs.
/// UNKNOWN is set when the classifier confidence is below the threshold (0.70),
/// routing the instance to MANUAL_REVIEW instead of auto-advancing.
enum ReplyIntent {
  POSITIVE
  NEGATIVE
  QUESTION
  OPT_OUT
  UNKNOWN
}

/// Coarse category for Event log entries, used for filtering and replay.
enum EventType {
  // Trigger events
  FOLLOW_UP_SCHEDULED
  FOLLOW_UP_CANCELLED
  FOLLOW_UP_DUE
  INBOUND_REPLY_RECEIVED
  // Transition events
  STATE_TRANSITION
  NODE_ENTERED
  NODE_COMPLETED
  // AI events
  OUTREACH_DRAFTED
  REPLY_CLASSIFIED
  NEGOTIATION_TURN
  MANUAL_REVIEW_FLAGGED
  // Manual queue: the brand was emailed that a creator needs human review.
  BRAND_NOTIFIED
  // Reward Setup: the agreement-confirmation email was sent to the creator.
  REWARD_SETUP_SENT
  // Reward Setup: the creator replied confirming the agreement.
  REWARD_CONFIRMED
  // Reward Setup: an inbound reply that did NOT confirm (kept in REWARD_PENDING).
  REWARD_REPLY_UNCONFIRMED
  // Payment Info: the payout-information request email was sent to the creator.
  PAYMENT_INFO_SENT
  // Payment Info: an inbound email reply arrived while awaiting the payout form
  // (often a re-negotiation attempt); a "rate is fixed" auto-reply was sent and
  // the instance stayed in PAYMENT_PENDING.
  PAYMENT_REPLY_UNRESOLVED
  // Payment Info: the creator submitted their payout information via the form.
  PAYMENT_RECEIVED
  // Content Brief: the campaign-brief email (PDF attachment + referral link) was
  // sent to the creator.
  CONTENT_BRIEF_SENT
}

/// Lifecycle of a Workflow definition.
enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// Definition models
// ---------------------------------------------------------------------------

/// A brand campaign. The top-level container created by brands in the wizard.
/// One Campaign can own multiple Workflows (e.g. different strategies for the same campaign).
model Campaign {
  id        String  @id @default(cuid())
  name      String
  brand     String
  objective String?
  notes     String?

  /// Brand contact email that receives manual-queue escalation notices.
  /// When a creator is escalated to MANUAL_REVIEW, the brand is emailed here so
  /// a human can take over. Nullable: campaigns created before this field, or
  /// brands that haven't supplied a contact, fall back to BRAND_NOTIFY_EMAIL
  /// (env) and finally the platform operator address (see notifications/escalation).
  notifyEmail String?

  /// Short description of what the brand does / sells. Fed to the LLM so it
  /// can answer creator questions like "what does your brand do?" without
  /// hallucinating. Stamped into every node's config as brandDescription.
  brandDescription String?

  /// What the creator is expected to produce (e.g. "3 IG Reels + 1 YouTube
  /// integration"). Free text supplied by the brand. Stamped into every node's
  /// config as `deliverables` so outreach/negotiation copy can state real scope
  /// instead of "to be finalized". Nullable: brands may leave it blank.
  deliverables String?

  /// When the content should go live (e.g. "content live by Sept 15, 2026").
  /// Free text supplied by the brand. Stamped into node config as `timeline`.
  /// The AI states it only when present, and never invents one when absent.
  timeline String?

  /// Free-text description of a product/sample the brand gives the creator as
  /// part of the reward (e.g. "a free pair of our running shoes"). Stamped into
  /// every node's config as `rewardDescription` so outreach/negotiation/reward
  /// copy can mention it. Nullable: cash-only campaigns leave it blank.
  rewardDescription String?

  /// Whether the reward includes a physical product that must be shipped. When
  /// true, the hosted Payment Info form also collects a shipping address.
  /// Stamped into every node's config as `shipsPhysicalProduct`.
  shipsPhysicalProduct Boolean @default(false)

  /// HARD-K1 knowledge fields — the campaign terms creators most often ask about
  /// that the agent previously had NOWHERE to source, so it hallucinated them by
  /// construction (see hard.md HARD-K1 / HARD-P2). All free text supplied by the
  /// brand and stamped into every node's config so /negotiate + /draft can state
  /// them as fact when present and DEFER honestly when absent (never invent).
  ///
  /// usageRights — how the brand may reuse the creator's content (e.g. "6-month
  /// paid social usage on the brand's handles").
  usageRights       String?
  /// exclusivity — any category exclusivity the creator must honor (e.g. "no
  /// competing footwear brands for 30 days after go-live").
  exclusivity       String?
  /// paymentTerms — when/how the creator is paid (e.g. "net-30 after content is
  /// approved, paid via bank transfer").
  paymentTerms      String?
  /// attributionWindow — the affiliate cookie/attribution window (e.g. "30-day
  /// last-click cookie").
  attributionWindow String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows Workflow[]
}

/// A campaign definition. The logical container for a sequence of nodes.
/// Editing a Workflow does not mutate existing WorkflowVersions.
model Workflow {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      WorkflowStatus @default(DRAFT)

  /// Nullable: existing seed workflows that predate Phase 10 have no campaign.
  campaignId String?
  /// Mutable draft: the in-progress node graph before publishing.
  /// Shape: NodeSnapshot[] (same as WorkflowVersion.nodeGraph).
  /// On publish this becomes an immutable WorkflowVersion row.
  draftNodes Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign?         @relation(fields: [campaignId], references: [id])
  versions WorkflowVersion[]
}

/// An immutable published snapshot of a Workflow.
/// Node configurations, types, and ordering are captured in `nodeGraph`
/// as a JSON array at publish time. Instances reference this record and
/// never see post-publish edits to the parent Workflow.
///
/// nodeGraph shape (array of NodeSnapshot):
///   [{ id, type, order, config: { ... node-specific fields ... } }]
model WorkflowVersion {
  id          String   @id @default(cuid())
  workflowId  String
  version     Int
  nodeGraph   Json
  publishedAt DateTime @default(now())

  createdAt DateTime @default(now())

  workflow  Workflow            @relation(fields: [workflowId], references: [id])
  instances ExecutionInstance[]

  @@unique([workflowId, version])
}

// ---------------------------------------------------------------------------
// Creator model
// ---------------------------------------------------------------------------

/// A mocked creator profile. In the prototype these are seeded rather than
/// imported from a real source. In production this would come from the
/// creator database.
model Creator {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  handle   String?
  niche    String?
  platform String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances ExecutionInstance[]
}

// ---------------------------------------------------------------------------
// Execution models
// ---------------------------------------------------------------------------

/// One Creator running through one WorkflowVersion.
/// This is the unit of execution, scheduling, and audit.
///
/// Scheduling fields (used from Phase 5):
///   followUpCount    — how many follow-ups have been sent; bounded by node config
///   negotiationRound — how many negotiation turns have occurred; bounded by node config
///   dueAt            — wall-clock time when the next scheduled action becomes due;
///                      persisted alongside the BullMQ delayed job for audit + recovery
///
/// Navigation field:
///   currentNodeId    — id of the node (within the version's nodeGraph) the instance
///                      is currently executing; null before the first node runs
///
/// State field:
///   currentState     — the InstanceState enum value; the state machine's single
///                      source of truth for this instance
model ExecutionInstance {
  id                String @id @default(cuid())
  workflowVersionId String
  creatorId         String

  currentState     InstanceState @default(ENROLLED)
  currentNodeId    String?
  followUpCount    Int           @default(0)
  negotiationRound Int           @default(0)
  dueAt            DateTime?

  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workflowVersion    WorkflowVersion     @relation(fields: [workflowVersionId], references: [id])
  creator            Creator             @relation(fields: [creatorId], references: [id])
  messages           Message[]
  events             Event[]
  brandNotifications BrandNotification[]
  brandDecisions     BrandDecision[]
  paymentInfo        PaymentInfo?
  outboxJobs         OutboxJob[]

  @@unique([workflowVersionId, creatorId])
  /// HARD-R1: the poller and reconciliation sweep both query by currentState
  /// (+ dueAt for the due-follow-up path). This composite index keeps those scans
  /// index-backed as the instance table grows instead of degrading to full scans.
  @@index([currentState, dueAt])
}

/// Every outbound and inbound email tied to an ExecutionInstance.
///
/// Email correlation fields (used from Phase 6):
///   threadId          — Nylas thread id; all messages in a conversation share
///                       the same threadId so replies can be matched to the
///                       correct instance
///   externalMessageId — Nylas message id for the individual message; used to
///                       deduplicate webhook deliveries
///
/// Classification fields (populated by LangGraph classify, Phase 7):
///   replyIntent       — classified intent of an inbound reply
///   classifyConfidence — confidence score (0–1) from the classifier
model Message {
  id                 String           @id @default(cuid())
  instanceId         String
  direction          MessageDirection
  subject            String?
  body               String
  threadId           String?
  /// The From: address of an INBOUND message (CRITICAL-1). Persisted so a brand
  /// decision reply can be verified to originate from the campaign's notifyEmail
  /// (the brand) rather than the creator — the party the system distrusts must
  /// not be able to resolve their own escalation. NULL for OUTBOUND messages and
  /// for inbound rows created before this field existed.
  senderEmail        String?
  externalMessageId  String?          @unique
  /// Deterministic pre-send key for OUTBOUND AI messages (Phase: remediation
  /// FIX-11). Computed BEFORE email.send() from stable inputs
  /// (instanceId + purpose + round), so a crash between send and the row write
  /// can be detected on retry and the send is not duplicated. NULL for inbound
  /// messages and for outbound messages that predate this field.
  idempotencyKey     String?          @unique
  replyIntent        ReplyIntent?
  classifyConfidence Float?
  sentAt             DateTime?
  receivedAt         DateTime?
  /// When an INBOUND reply finished PROCESSING (CRITICAL-6). Set only after the
  /// full inbound handler completes (persist → transition → step). The worker's
  /// idempotency short-circuit keys on this, not on mere row existence: a reply
  /// persisted but not yet processed (a crash mid-handler) has processedAt NULL,
  /// so a BullMQ retry re-processes it instead of no-op'ing and losing it. NULL
  /// for OUTBOUND rows and for inbound rows that predate this field.
  processedAt        DateTime?

  createdAt DateTime @default(now())

  instance ExecutionInstance @relation(fields: [instanceId], references: [id])

  @@index([threadId])
  @@index([instanceId])
}

/// Append-only audit log of every trigger and state transition for an
/// ExecutionInstance. Never updated or deleted.
///
/// payload — free-form JSON capturing event-specific context:
///   STATE_TRANSITION: { from, to }
///   FOLLOW_UP_DUE:    { followUpCount, jobId }
///   REPLY_CLASSIFIED: { intent, confidence, messageId }
///   NEGOTIATION_TURN: { round, action }
///   etc.
model Event {
  id         String    @id @default(cuid())
  instanceId String
  type       EventType
  nodeId     String?
  payload    Json?
  occurredAt DateTime  @default(now())

  instance ExecutionInstance @relation(fields: [instanceId], references: [id])

  @@index([instanceId, occurredAt])
}

/// Transactional outbox (HARD-R1 — SCAFFOLD, not yet wired into every enqueue).
///
/// The reliability gap this closes: today a state commit (OCC update) and the
/// follow-on job enqueue are two separate operations. A crash / Redis blip
/// between them strands the instance — the state moved but no job was queued. The
/// reconciliation sweep (scheduler/reconciliation.ts) recovers such strands by
/// re-enqueuing stuck states, and is the operational backstop in place now.
///
/// The DURABLE fix is this outbox: at each OCC commit, write the intended job to
/// this table IN THE SAME TRANSACTION as the state change, then a relay drains
/// PENDING rows to BullMQ and marks them SENT. Because the row and the state
/// commit are atomic, a job is never lost; because the relay is idempotent on
/// (instanceId + triggerRef), it is never double-enqueued.
///
/// This model + status enum are the schema seam so the relay + per-call-site
/// writes can land next without another migration. The sweep is the interim
/// guarantee until the relay is wired.
enum OutboxStatus {
  PENDING
  SENT
  FAILED
}

model OutboxJob {
  id         String       @id @default(cuid())
  instanceId String
  /// The queue this job targets (e.g. "node-execution"). Kept as a string so a
  /// new queue doesn't require a migration.
  queue      String
  /// The BullMQ job payload, verbatim (e.g. { expectedState, triggerRef }).
  payload    Json
  /// Idempotency key mirroring the BullMQ jobId (triggerRef) so the relay never
  /// double-enqueues and a duplicate write is a no-op.
  dedupeKey  String       @unique
  status     OutboxStatus @default(PENDING)
  attempts   Int          @default(0)
  lastError  String?
  createdAt  DateTime     @default(now())
  sentAt     DateTime?

  instance ExecutionInstance @relation(fields: [instanceId], references: [id])

  /// The relay scans PENDING oldest-first; this index keeps that scan cheap.
  @@index([status, createdAt])
  @@index([instanceId])
}

/// A record of a manual-queue escalation notice sent to the brand.
///
/// One row is written each time a creator's ExecutionInstance enters
/// MANUAL_REVIEW and the brand is notified. The unique idempotencyKey
/// (instanceId + reason) makes the send-and-record path safe under BullMQ
/// retries: a second attempt for the same escalation hits the unique constraint
/// and is skipped, so the brand is never double-emailed for the same event.
///
/// status:
///   SENT   — the email was handed to the email provider successfully
///   FAILED — the provider threw; the row is kept so the UI can surface that the
///            brand was NOT reached and a human can follow up out of band
///   SKIPPED — no recipient could be resolved (no campaign notifyEmail, no env,
///            no operator default); recorded for audit, no email attempted
enum BrandNotificationStatus {
  SENT
  FAILED
  SKIPPED
}

model BrandNotification {
  id             String                  @id @default(cuid())
  instanceId     String
  /// Resolved recipient address the notice was (or would have been) sent to.
  recipient      String
  /// Why the creator was escalated, e.g. "low_confidence_reply",
  /// "max_rounds_reached", "output_guard_blocked", "escalated".
  reason         String
  status         BrandNotificationStatus @default(SENT)
  /// Deterministic key (instanceId + reason) enforcing at-most-once delivery
  /// per escalation event.
  idempotencyKey String                  @unique
  /// Provider error message when status = FAILED. Null otherwise.
  error          String?

  createdAt DateTime @default(now())

  instance ExecutionInstance @relation(fields: [instanceId], references: [id])

  @@index([instanceId])
}

/// The lifecycle of one brand-decision round-trip (see MANUAL_ESCALATION_RESOLUTION.md §2.2).
///
/// A BrandDecision is created when a *business* escalation parks the run in
/// AWAITING_BRAND_DECISION and we email the brand an actionable question. It is
/// resolved when the brand replies (free-text reply parsed, or a magic-link click).
///
///   PENDING    — emailed the brand; awaiting their reply.
///   RESOLVED   — brand gave a parseable decision (approve/reject/counter); run resumed.
///   REASKED    — the reply was ambiguous; one clarification email was sent (cap 1).
///   HANDED_OFF — brand asked for a full human handoff → MANUAL_REVIEW.
///   EXPIRED    — 72h silence timeout swept the row → MANUAL_REVIEW + operator ping.
enum BrandDecisionStatus {
  PENDING
  RESOLVED
  REASKED
  HANDED_OFF
  EXPIRED
}

/// A round-trip brand decision that resolves a business escalation by email.
///
/// Modeled on BrandNotification (idempotency-keyed brand contact), extended to a
/// full request/response cycle. The `token` is the key trick: it is embedded in
/// the escalation email's reply-to/subject AND in the magic-link URLs, so an
/// inbound reply (or a button click) matches back to this row → instanceId,
/// exactly the way the PaymentInfo token resolves a hosted-form submission back
/// to an instance.
model BrandDecision {
  id         String @id @default(cuid())
  instanceId String

  /// The escalation reason code that triggered this decision (mirrors the codes
  /// used by BrandNotification.reason, e.g. "low_confidence_reply",
  /// "max_rounds_reached", "escalated", "missing_brand_name").
  reason   String
  /// The human-readable question we asked the brand, persisted for the timeline.
  question String
  /// Opaque, unguessable token embedded in the reply-to + magic links. Matches
  /// inbound replies / link clicks back to this decision. UNIQUE — it is the
  /// capability that authorizes resolving exactly this decision.
  token    String              @unique
  status   BrandDecisionStatus @default(PENDING)

  /// Captured context needed to resume without re-deriving it from the thread:
  /// creator rate, current round, floor/ceiling band, guard details, injection
  /// flag, the blocked node id, etc. Shape is per-reason.
  contextJson Json

  /// The brand's raw reply body (audit trail). Null until a reply arrives.
  brandReplyRaw String?
  /// The parsed decision: APPROVE | REJECT | COUNTER | HANDOFF | AMBIGUOUS.
  /// Null until parsed.
  decision      String?
  /// The numeric value attached to the decision (the counter amount when
  /// decision = COUNTER; the supplied rate/config value for variant cases).
  decisionValue Float?

  /// How many clarification round-trips have happened. Capped at 1: a second
  /// ambiguous reply parks the run in the dashboard (MANUAL_REVIEW).
  reaskCount Int       @default(0)
  /// Silence timeout. A PENDING decision past this instant is swept into
  /// MANUAL_REVIEW by the scheduler (default 72h from creation).
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  instance ExecutionInstance @relation(fields: [instanceId], references: [id])

  @@index([instanceId])
}

/// The payout information collected by the Payment Info node.
///
/// One row per ExecutionInstance (created when the Payment Info node runs). The
/// `token` is a secure, unguessable id embedded in the hosted payout-form link
/// (http://localhost:3001/payment/{token}); it resolves back to the creator,
/// campaign, and workflow execution via the parent ExecutionInstance. No auth is
/// required — the token IS the capability (prototype scope).
///
/// Extensibility: additional payout fields (tax info, routing numbers, invoice
/// refs, verification status) can be added later either as first-class columns
/// or inside `extra` (free-form JSON) without changing the node's control flow.
///
/// status:
///   PAYMENT_PENDING  — link sent; the creator has not submitted the form yet.
///   PAYMENT_RECEIVED — the creator submitted; the node completes and the engine
///                      resumes into the next connected node.
enum PaymentInfoStatus {
  PAYMENT_PENDING
  PAYMENT_RECEIVED
}

enum PayoutMethod {
  PAYPAL
  WISE
  BANK_TRANSFER
}

model PaymentInfo {
  id         String            @id @default(cuid())
  instanceId String            @unique
  /// Secure, unguessable token used in the hosted form URL. The capability that
  /// authorizes an unauthenticated submission for exactly this instance.
  token      String            @unique
  status     PaymentInfoStatus @default(PAYMENT_PENDING)

  /// Submitted payout fields. Null until the creator submits the form.
  method            PayoutMethod?
  /// PayPal/Wise email or bank account identifier — free text (prototype: not
  /// validated against any payment provider).
  accountIdentifier String?
  country           String?
  notes             String?
  /// Room to grow: any future payout fields collected before a dedicated column
  /// exists (tax id, routing number, invoice ref, verification result, …).
  extra             Json?

  /// MED-S5: token lifecycle. A payout link is a bearer capability, so a leaked
  /// or forwarded link must not work forever — the hosted routes reject an
  /// unsubmitted token past this instant. Set at creation (default 30 days);
  /// nullable for rows created before the column existed (treated as no expiry).
  expiresAt DateTime?

  createdAt   DateTime  @default(now())
  submittedAt DateTime?
  updatedAt   DateTime  @updatedAt

  instance ExecutionInstance @relation(fields: [instanceId], references: [id])

  @@index([instanceId])
}
