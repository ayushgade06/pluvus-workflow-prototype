// =============================================================================
// Pluvus Workflow Prototype — Prisma Schema
// Architecture ref: .claude/docs/system-architecture.md §6
//
// Design principles:
//   - Definition models (Workflow, WorkflowVersion) are separated from
//     execution models (ExecutionInstance, Message, Event).
//   - WorkflowVersion is immutable once published. Node configs are stored
//     as a JSON snapshot so instances stay pinned to the version they enrolled
//     under, regardless of later edits to the Workflow.
//   - ExecutionInstance is the unit of execution, scheduling, and audit.
//   - Event is append-only. Never update or delete rows.
//   - Message stores every inbound and outbound email tied to an instance,
//     with fields for Nylas thread/message id correlation (Phase 6).
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// The lifecycle state of a single creator running through a workflow.
/// Source of truth: source-of-truth.md §6
enum InstanceState {
  ENROLLED
  OUTREACH_SENT
  AWAITING_REPLY
  FOLLOWED_UP
  REPLY_RECEIVED
  NEGOTIATING
  // Terminal states
  ACCEPTED
  REJECTED
  OPTED_OUT
  NO_RESPONSE
  // Requires human review (low-confidence classification, Phase 7)
  MANUAL_REVIEW
}

/// The node types that make up the in-scope linear workflow.
/// Stored here so node snapshots inside WorkflowVersion.nodeGraph can be
/// validated at the application layer without magic strings.
enum NodeType {
  IMPORT_CREATOR_LIST
  INITIAL_OUTREACH
  FOLLOW_UP
  REPLY_DETECTION
  NEGOTIATION
  END
}

/// Direction of a message: sent by us (OUTBOUND) or received (INBOUND).
enum MessageDirection {
  OUTBOUND
  INBOUND
}

/// The classified intent of an inbound reply. Populated by the LangGraph
/// classify operation (Phase 7). NULL until classification runs.
/// UNKNOWN is set when the classifier confidence is below the threshold (0.70),
/// routing the instance to MANUAL_REVIEW instead of auto-advancing.
enum ReplyIntent {
  POSITIVE
  NEGATIVE
  QUESTION
  OPT_OUT
  UNKNOWN
}

/// Coarse category for Event log entries, used for filtering and replay.
enum EventType {
  // Trigger events
  FOLLOW_UP_SCHEDULED
  FOLLOW_UP_CANCELLED
  FOLLOW_UP_DUE
  INBOUND_REPLY_RECEIVED
  // Transition events
  STATE_TRANSITION
  NODE_ENTERED
  NODE_COMPLETED
  // AI events
  OUTREACH_DRAFTED
  REPLY_CLASSIFIED
  NEGOTIATION_TURN
  MANUAL_REVIEW_FLAGGED
  // Manual queue: the brand was emailed that a creator needs human review.
  BRAND_NOTIFIED
}

/// Lifecycle of a Workflow definition.
enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// Definition models
// ---------------------------------------------------------------------------

/// A brand campaign. The top-level container created by brands in the wizard.
/// One Campaign can own multiple Workflows (e.g. different strategies for the same campaign).
model Campaign {
  id        String  @id @default(cuid())
  name      String
  brand     String
  objective String?
  notes     String?

  /// Brand contact email that receives manual-queue escalation notices.
  /// When a creator is escalated to MANUAL_REVIEW, the brand is emailed here so
  /// a human can take over. Nullable: campaigns created before this field, or
  /// brands that haven't supplied a contact, fall back to BRAND_NOTIFY_EMAIL
  /// (env) and finally the platform operator address (see notifications/escalation).
  notifyEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows Workflow[]
}

/// A campaign definition. The logical container for a sequence of nodes.
/// Editing a Workflow does not mutate existing WorkflowVersions.
model Workflow {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      WorkflowStatus @default(DRAFT)

  /// Nullable: existing seed workflows that predate Phase 10 have no campaign.
  campaignId String?
  /// Mutable draft: the in-progress node graph before publishing.
  /// Shape: NodeSnapshot[] (same as WorkflowVersion.nodeGraph).
  /// On publish this becomes an immutable WorkflowVersion row.
  draftNodes Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign?       @relation(fields: [campaignId], references: [id])
  versions WorkflowVersion[]
}

/// An immutable published snapshot of a Workflow.
/// Node configurations, types, and ordering are captured in `nodeGraph`
/// as a JSON array at publish time. Instances reference this record and
/// never see post-publish edits to the parent Workflow.
///
/// nodeGraph shape (array of NodeSnapshot):
///   [{ id, type, order, config: { ... node-specific fields ... } }]
model WorkflowVersion {
  id         String   @id @default(cuid())
  workflowId String
  version    Int
  nodeGraph  Json
  publishedAt DateTime @default(now())

  createdAt DateTime @default(now())

  workflow  Workflow            @relation(fields: [workflowId], references: [id])
  instances ExecutionInstance[]

  @@unique([workflowId, version])
}

// ---------------------------------------------------------------------------
// Creator model
// ---------------------------------------------------------------------------

/// A mocked creator profile. In the prototype these are seeded rather than
/// imported from a real source. In production this would come from the
/// creator database.
model Creator {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  handle   String?
  niche    String?
  platform String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances ExecutionInstance[]
}

// ---------------------------------------------------------------------------
// Execution models
// ---------------------------------------------------------------------------

/// One Creator running through one WorkflowVersion.
/// This is the unit of execution, scheduling, and audit.
///
/// Scheduling fields (used from Phase 5):
///   followUpCount    — how many follow-ups have been sent; bounded by node config
///   negotiationRound — how many negotiation turns have occurred; bounded by node config
///   dueAt            — wall-clock time when the next scheduled action becomes due;
///                      persisted alongside the BullMQ delayed job for audit + recovery
///
/// Navigation field:
///   currentNodeId    — id of the node (within the version's nodeGraph) the instance
///                      is currently executing; null before the first node runs
///
/// State field:
///   currentState     — the InstanceState enum value; the state machine's single
///                      source of truth for this instance
model ExecutionInstance {
  id                String        @id @default(cuid())
  workflowVersionId String
  creatorId         String

  currentState     InstanceState @default(ENROLLED)
  currentNodeId    String?
  followUpCount    Int           @default(0)
  negotiationRound Int           @default(0)
  dueAt            DateTime?

  enrolledAt   DateTime  @default(now())
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workflowVersion WorkflowVersion @relation(fields: [workflowVersionId], references: [id])
  creator         Creator         @relation(fields: [creatorId], references: [id])
  messages        Message[]
  events          Event[]
  brandNotifications BrandNotification[]

  @@unique([workflowVersionId, creatorId])
}

/// Every outbound and inbound email tied to an ExecutionInstance.
///
/// Email correlation fields (used from Phase 6):
///   threadId          — Nylas thread id; all messages in a conversation share
///                       the same threadId so replies can be matched to the
///                       correct instance
///   externalMessageId — Nylas message id for the individual message; used to
///                       deduplicate webhook deliveries
///
/// Classification fields (populated by LangGraph classify, Phase 7):
///   replyIntent       — classified intent of an inbound reply
///   classifyConfidence — confidence score (0–1) from the classifier
model Message {
  id                  String           @id @default(cuid())
  instanceId          String
  direction           MessageDirection
  subject             String?
  body                String
  threadId            String?
  externalMessageId   String?          @unique
  /// Deterministic pre-send key for OUTBOUND AI messages (Phase: remediation
  /// FIX-11). Computed BEFORE email.send() from stable inputs
  /// (instanceId + purpose + round), so a crash between send and the row write
  /// can be detected on retry and the send is not duplicated. NULL for inbound
  /// messages and for outbound messages that predate this field.
  idempotencyKey      String?          @unique
  replyIntent         ReplyIntent?
  classifyConfidence  Float?
  sentAt              DateTime?
  receivedAt          DateTime?

  createdAt DateTime @default(now())

  instance ExecutionInstance @relation(fields: [instanceId], references: [id])

  @@index([threadId])
  @@index([instanceId])
}

/// Append-only audit log of every trigger and state transition for an
/// ExecutionInstance. Never updated or deleted.
///
/// payload — free-form JSON capturing event-specific context:
///   STATE_TRANSITION: { from, to }
///   FOLLOW_UP_DUE:    { followUpCount, jobId }
///   REPLY_CLASSIFIED: { intent, confidence, messageId }
///   NEGOTIATION_TURN: { round, action }
///   etc.
model Event {
  id         String    @id @default(cuid())
  instanceId String
  type       EventType
  nodeId     String?
  payload    Json?
  occurredAt DateTime  @default(now())

  instance ExecutionInstance @relation(fields: [instanceId], references: [id])

  @@index([instanceId, occurredAt])
}

/// A record of a manual-queue escalation notice sent to the brand.
///
/// One row is written each time a creator's ExecutionInstance enters
/// MANUAL_REVIEW and the brand is notified. The unique idempotencyKey
/// (instanceId + reason) makes the send-and-record path safe under BullMQ
/// retries: a second attempt for the same escalation hits the unique constraint
/// and is skipped, so the brand is never double-emailed for the same event.
///
/// status:
///   SENT   — the email was handed to the email provider successfully
///   FAILED — the provider threw; the row is kept so the UI can surface that the
///            brand was NOT reached and a human can follow up out of band
///   SKIPPED — no recipient could be resolved (no campaign notifyEmail, no env,
///            no operator default); recorded for audit, no email attempted
enum BrandNotificationStatus {
  SENT
  FAILED
  SKIPPED
}

model BrandNotification {
  id         String                  @id @default(cuid())
  instanceId String
  /// Resolved recipient address the notice was (or would have been) sent to.
  recipient  String
  /// Why the creator was escalated, e.g. "low_confidence_reply",
  /// "max_rounds_reached", "output_guard_blocked", "escalated".
  reason     String
  status     BrandNotificationStatus @default(SENT)
  /// Deterministic key (instanceId + reason) enforcing at-most-once delivery
  /// per escalation event.
  idempotencyKey String              @unique
  /// Provider error message when status = FAILED. Null otherwise.
  error      String?

  createdAt DateTime @default(now())

  instance ExecutionInstance @relation(fields: [instanceId], references: [id])

  @@index([instanceId])
}
