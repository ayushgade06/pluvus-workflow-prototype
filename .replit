modules = ["nodejs-20", "python-3.12", "web"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[userenv]

[userenv.shared]
AGENT_PROVIDER = "langgraph"
AGENT_SERVICE_URL = "http://localhost:8000"
ENABLE_QUEUE_INJECTION = "false"
LLM_PROVIDER = "openrouter"
NEGOTIATION_PROVIDER = "langgraph"
PROCESS_ROLE = "all"
REDIS_URL = "redis://localhost:6379"
WORKER_CONCURRENCY = "2"
OPENROUTER_BASE_URL = "https://openrouter.ai/api/v1"
OPENROUTER_MAX_RETRIES = "2"
OPENROUTER_MODEL = "anthropic/claude-opus-4.8"
OPENROUTER_MODEL_DRAFT = "deepseek/deepseek-chat"
OPENROUTER_TIMEOUT_SECONDS = "60"
LLM_DAILY_SPEND_ALERT_USD = "25"
LLM_MAX_REQUEST_COST_USD = "0.50"
NEGOTIATION_STRATEGY = "llm"
VITE_OPERATOR_API_KEY = "OacUIV_6YbVtLPbzJH0W7gLw0UYDjAFS"

[userenv.development]
AGENT_ENV = "development"
EMAIL_PROVIDER = "mock"
NODE_ENV = "development"
PORT = "3001"

[userenv.production]
AGENT_ENV = "production"
EMAIL_PROVIDER = "nylas"
NODE_ENV = "production"
PAYMENT_BASE_URL = "https://pluvus-workflow-prototype.replit.app"
PORT = "3000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Agent"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev:web"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c \"redis-server --port 6379 &>/tmp/redis.log & sleep 1 && npm run dev:server\""
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Agent"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd agent && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"
waitForPort = 8000

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "cloudrun"
run = ["bash", "start-prod.sh"]
build = ["bash", "-c", "npm run build && cd agent && pip install -e '.[ai]'"]
