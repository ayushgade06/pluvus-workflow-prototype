# ============================================================
# Pluvus Workflow Prototype — Environment Variables (example)
# Copy this file to .env and fill in real values for local dev.
# .env is gitignored; this committed example carries no secrets.
# ============================================================

# --- Server ---
PORT=3001
NODE_ENV=development
# W-4: opt-in gate for the queue-injection endpoints (POST /queues/node-execution,
# POST /queues/inbound-email). These enqueue REAL jobs that drive the live state
# machine — inbound-email can force a mockIntent (a fabricated creator reply) —
# so they answer 404 unless NODE_ENV=test or this is explicitly "true" on a
# trusted local dev/harness box. NEVER set in a deployed environment.
ENABLE_QUEUE_INJECTION=false

# --- Database (Phase 2) ---
# PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- Redis (Phase 4+) ---
# Redis URL for BullMQ and the per-instance locks.
REDIS_URL=redis://localhost:6379

# --- Agent service ---
# URL of the Python LangGraph agent service (TS providers read AGENT_SERVICE_URL).
AGENT_SERVICE_URL=http://localhost:8001
# Route classification + negotiation through the real LangGraph agent (no mock).
#   mock     → in-process rule/keyword providers (harness only)
#   langgraph → HTTP to the agent service above (real AI)
AGENT_PROVIDER=langgraph
NEGOTIATION_PROVIDER=langgraph
# Shared secret protecting /classify, /negotiate, /draft on the agent service
# (FIX-12). The TS providers send it as `Authorization: Bearer <key>`; the agent
# service checks it against AGENT_API_KEY. Leave BOTH unset for local dev /
# harnesses (auth disabled, a warning is logged). Set the SAME value on both
# sides in any deployed environment.
AGENT_API_KEY=
# Per-request timeout (ms) the TS side applies to the GENERATION routes
# (/negotiate, /draft). Default 120000 (C3). This MUST exceed the Python side's
# per-invoke budget × retries, or the HTTP request is aborted before the model
# finishes generating: a local Qwen call is ~38s, and a generation + one repair
# retry can take ~80s. The prior 30000 aborted before even the first generation
# completed, tripping the breaker and dumping every turn to MANUAL_REVIEW.
AGENT_TIMEOUT_MS=120000
# Shorter fail-fast timeout (ms) for the /classify route only (default 45000).
# Classification is a single short generation on the interactive reply path, so
# it should not hold a worker as long as a full draft — but still above one Qwen
# call (~38s) so a normal classify completes.
AGENT_CLASSIFY_TIMEOUT_MS=45000
# Circuit breaker (FIX-9): after AGENT_CB_FAILURE_THRESHOLD consecutive failures
# the TS side stops calling the agent service and fast-fails for
# AGENT_CB_COOLDOWN_MS, then allows one probe. While the circuit is open the
# orchestration degrades to MANUAL_REVIEW (classify→UNKNOWN, negotiate→escalate)
# instead of hammering a dead backend. Defaults 5 / 30000.
AGENT_CB_FAILURE_THRESHOLD=5
AGENT_CB_COOLDOWN_MS=30000
# Python-side per-invoke wall-clock budget (seconds). Bounds a hung llm.invoke so
# it can't pin the FastAPI worker even though the TS request already aborted.
# Set 0 to disable. Default 60 (FIX-9).
LLM_INVOKE_TIMEOUT_SECONDS=60
# Rate limit on the agent service: max requests per window per client+route, and
# the window length in seconds. Set AGENT_RATE_LIMIT=0 to disable. Default 60/60s.
AGENT_RATE_LIMIT=60
AGENT_RATE_WINDOW_SECONDS=60

# --- Nylas (Phase 6) ---
# Email provider selector: "mock" (default, no real email) or "nylas".
# Leave as mock for local dev / harnesses; flip to nylas in a sandbox env.
EMAIL_PROVIDER=mock
# Nylas API credentials. Required only when EMAIL_PROVIDER=nylas.
NYLAS_API_KEY=
NYLAS_GRANT_ID=
# Webhook signing secret (the webhook_secret Nylas returns when you create the
# webhook destination). Used to verify the X-Nylas-Signature header on inbound
# deliveries. Required for the /webhooks/nylas route to accept events.
NYLAS_WEBHOOK_SECRET=
# Optional: API base URI override (e.g. https://api.us.nylas.com).
NYLAS_API_URI=

# --- Manual queue escalation notices (Phase 11) ---
# When a creator is escalated to the manual review queue, the brand is emailed so
# a human can take over. Recipient precedence:
#   1. the campaign's notifyEmail (set per-campaign in the wizard)
#   2. BRAND_NOTIFY_EMAIL below (workspace-wide default)
#   3. the platform operator address (affiliatepartner@pluvus.com) as a last resort
# Leave blank to fall through to the operator default.
BRAND_NOTIFY_EMAIL=

# ============================================================
# --- LLM provider (agent service) ---
# LLM_PROVIDER is the GLOBAL default backing every LangGraph agent. No code edits.
#   LLM_PROVIDER=anthropic  → Claude (default) — set ANTHROPIC_API_KEY below
#   LLM_PROVIDER=deepseek   → DeepSeek cloud — set DEEPSEEK_API_KEY below
#   LLM_PROVIDER=ollama     → local Qwen via Ollama (dev/testing, no API key)
LLM_PROVIDER=anthropic
# Optional failover (FIX-8): if the primary provider fails on a call, fall over
# to this one. Leave blank for no failover (the common case). Configure the
# fallback's own model/key env below. Example: LLM_FALLBACK_PROVIDER=deepseek
LLM_FALLBACK_PROVIDER=

# Per-TASK provider override (mixed-model deployment). Each role — negotiate,
# classify, draft — pins its OWN provider via LLM_PROVIDER_<ROLE>, inheriting
# LLM_PROVIDER above when blank. Each role also honors LLM_FALLBACK_PROVIDER_<ROLE>.
# Example split: Claude on the money/decision path, DeepSeek for email copy:
#   LLM_PROVIDER_NEGOTIATE=   (blank → inherits LLM_PROVIDER)
#   LLM_PROVIDER_CLASSIFY=    (blank → inherits LLM_PROVIDER)
#   LLM_PROVIDER_DRAFT=deepseek
LLM_PROVIDER_DRAFT=

# Negotiation decision engine.
#   NEGOTIATION_STRATEGY=rules  → deterministic (model classifies + extracts,
#                                 code picks accept/counter/escalate + the number)
#   NEGOTIATION_STRATEGY=llm    → the model reads the full history and picks the
#                                 action AND rate itself, bounded to [floor,
#                                 ceiling] + round cap; falls back to rules on any
#                                 LLM/transport failure.
NEGOTIATION_STRATEGY=rules

# Anthropic / Claude (prod) — used when LLM_PROVIDER=anthropic (default)
# Steps to run: (1) pip install langchain-anthropic  (2) set ANTHROPIC_API_KEY
#   (3) restart the agent service. ANTHROPIC_MODEL is itself the pin — use an
# exact model id from the Claude catalog:
#   claude-opus-4-8   → most capable (default)
#   claude-haiku-4-5  → fastest + cheapest
#   claude-sonnet-4-6 → balanced
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
# Optional Claude knobs (sane defaults; override only if needed):
#   ANTHROPIC_MAX_TOKENS      cap on generated tokens (default 768; negotiate route
#                             passes a larger per-call override for its long JSON)
#   ANTHROPIC_TIMEOUT_SECONDS per-request SDK timeout (default 60)
#   ANTHROPIC_MAX_RETRIES     SDK auto-retries on 429/5xx (default 2)
# ANTHROPIC_MAX_TOKENS=768

# DeepSeek (cloud) — used when a provider slot resolves to deepseek (e.g.
# LLM_PROVIDER_DRAFT=deepseek). OpenAI-compatible, so it rides langchain-openai
# (already installed). Steps: set DEEPSEEK_API_KEY (platform.deepseek.com) and
# restart the agent. DEEPSEEK_MODEL is the pin:
#   deepseek-chat     → V3, strong + cheap for email copy (default)
#   deepseek-reasoner → R1, only if a path needs a visible chain of thought
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
# Optional DeepSeek knobs (sane defaults; override only if needed):
#   DEEPSEEK_BASE_URL         default https://api.deepseek.com (override for a proxy)
#   DEEPSEEK_MAX_TOKENS       cap on generated tokens (default 768)
#   DEEPSEEK_TIMEOUT_SECONDS  per-request SDK timeout (default 60)
#   DEEPSEEK_MAX_RETRIES      SDK auto-retries on 429/5xx (default 2)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama (local dev) — used when LLM_PROVIDER=ollama
# qwen3:8b is the practical local default: on a 6GB GPU it runs mostly on the GPU
# (~5.2GB), so generation is 5-10x faster than the 30B MoE (19GB, ~75% spills to
# CPU). The AGENT_TIMEOUT_MS / LLM_INVOKE_TIMEOUT_SECONDS above are sized for it.
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
# Optional (FIX-8): pin Ollama to an immutable build digest so a later
# `ollama pull` of the same tag can't silently change the decision path. Get it
# from `ollama show qwen3:8b`. Accepts "sha256:<hex>" or bare "<hex>".
OLLAMA_MODEL_DIGEST=
# ============================================================
